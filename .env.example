# Spring Boot and docker compose both load this file.
# Copy to .env and replace the placeholder values before deployment.

TZ=Asia/Shanghai

MYSQL_ROOT_PASSWORD=change-me
MYSQL_DATABASE=pets_db
MYSQL_PORT=3306
BACKEND_PORT=18080

SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/pets_db?useUnicode=true&characterEncoding=utf-8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=change-me

PETS_SERVER_PUBLIC_BASE_URL=https://api.itsbrain.me
CLOUDFLARED_TUNNEL_TOKEN=your-cloudflare-tunnel-token

ALIPAY_APP_ID=your-sandbox-app-id
ALIPAY_PRIVATE_KEY=your-rsa2-private-key-without-header-footer
ALIPAY_PUBLIC_KEY=your-alipay-public-key-without-header-footer
ALIPAY_SERVER_URL=https://openapi-sandbox.dl.alipaydev.com/gateway.do
ALIPAY_NOTIFY_URL=https://your-public-domain/api/v1/payments/alipay/notify
ALIPAY_RETURN_URL=https://your-public-domain/pay-return
ALIPAY_PAGE_QUIT_URL=https://your-public-domain/pay-quit
ALIPAY_SIGN_TYPE=RSA2
ALIPAY_CHARSET=UTF-8
ALIPAY_FORMAT=json

ALIYUN_OSS_ACCESS_KEY_ID=your-access-key-id
ALIYUN_OSS_ACCESS_KEY_SECRET=your-access-key-secret
PETS_SMS_REAL_SEND=false

PETS_JWT_SECRET=change-this-to-a-long-random-secret
